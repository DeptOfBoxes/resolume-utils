<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Filled in by install.sh — do not edit by hand -->
  <key>Label</key>
  <string>com.deptofboxes.cubeport-status</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__SCRIPT__</string>
  </array>

  <!-- Start at login, restart if it crashes -->
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <!-- Needs a GUI session; launchd must run as the user, not root -->
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>

  <key>StandardOutPath</key>
  <string>/tmp/cubeport-status.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/cubeport-status.log</string>
</dict>
</plist>
